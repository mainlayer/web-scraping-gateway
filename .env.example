# Web Scraping Gateway — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Mainlayer payment verification
# ---------------------------------------------------------------------------
# Your Mainlayer API key for verifying agent payments.
# Get one at: https://app.mainlayer.xyz
MAINLAYER_API_KEY=ml_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL for the Mainlayer API (default: https://api.mainlayer.xyz)
MAINLAYER_BASE_URL=https://api.mainlayer.xyz

# Timeout in seconds for Mainlayer API calls (default: 5)
MAINLAYER_TIMEOUT=5

# ---------------------------------------------------------------------------
# Resource identification
# ---------------------------------------------------------------------------
# Unique identifier for this gateway instance, used for payment verification.
RESOURCE_ID=web-scraping-gateway-v1

# ---------------------------------------------------------------------------
# Cache settings
# ---------------------------------------------------------------------------
# Maximum number of entries in the in-memory LRU cache (default: 500)
CACHE_MAX_SIZE=500

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# Maximum requests per wallet per window (default: 60)
RATE_LIMIT_MAX_REQUESTS=60

# Rate limit window in seconds (default: 60)
RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Server settings
# ---------------------------------------------------------------------------
# Host and port for uvicorn
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
